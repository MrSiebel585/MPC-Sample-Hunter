Fryq4qpAxUIARUAAAAAGAElAADIQj0AgKJDeAE=&rs=AOn4CLDuGu1nZeZtHZSi2yLdOjny6-spKQ", "height": 188, "width": 336, "preference": -7, "id": "33", "resolution": "336x188"}, {"url": "https://i.ytimg.com/vi/rbX3UFDH_OE/hqdefault.jpg", "height": 360, "width": 480, "preference": -7, "id": "34", "resolution": "480x360"}, {"url": "https://i.ytimg.com/vi_webp/rbX3UFDH_OE/hqdefault.webp", "preference": -6, "id": "35"}, {"url": "https://i.ytimg.com/vi/rbX3UFDH_OE/sddefault.jpg", "height": 480, "width": 640, "preference": -5, "id": "36", "resolution": "640x480"}, {"url": "https://i.ytimg.com/vi_webp/rbX3UFDH_OE/sddefault.webp", "preference": -4, "id": "37"}], "thumbnail": "https://i.ytimg.com/vi/rbX3UFDH_OE/sddefault.jpg", "description": "Loopmasters present Stranger Synths (http://www.loopmasters.com/products/5543)\n\nGET 50% OFF BETWEEN OCT 27th - NOV 5th 2017.\n\nAn ambient collection of evolving synth atmospheres from a Grammy Award winning engineer and producer. Featuring heavy analogue synths, lush pads and evolving FX, Stranger Synths is 100% royalty free and is the perfect soundtrack to a strange world in a parallel dimension.\n\nStranger Synths is the brainchild of Dom Morley, who has worked with a wide variety of artists from Amy Winehouse and Richard Ashcroft to Underworld and Lemonjelly. His obsession with modular synths has meant a whole wall in his studio is now dedicated to his ever-growing collection at his Flint Barn Studio – where Stranger Synths was created.\n\nThis collection was inspired by the sounds and moods of the Netflix series `Stranger Things’ and features the sounds of the Mos-Lab, MacBeth, Wiard, Modcan, MOTM and a huge variety of Eurorack modules, recorded through vintage Telefunken mic-pres and treated with an assortment of pedals and outboard compressors and EQs.\n\nStranger Synths comes as 35 Construction Kits, featuring Arpeggios, Basses, Sequences, Pads, Synths and FX Loops, with 174 separate Loops at tempos between 80 and 110BPM. You’ll be able to mix the cream of the Doms modular labyrinth from the comfort of your own studio, with sounds reminiscent of John Carpenter, Vangelis and the rising Synthwave generation.\n\nStranger Synths has the full frequency range covered, with Sweeps, Bells, Leads, Brass, Chimes and Sequences all primed for a Synthetic future. At 80, 90, 100 and 110 BPM in a range of musical keys, you’ll find the right mix of content for Ambient, Chillout, Soundtracks, Hiphop, Synthwave and Downtempo Genres.\n\nDownload the free taster pack here: http://www.loopmasters.com/products/5543\n\nGET 50% OFF BETWEEN OCT 27th - NOV 5th 2017.", "channel_id": "UC-KH022doPmcEwrWtSqmSpg", "channel_url": "https://www.youtube.com/channel/UC-KH022doPmcEwrWtSqmSpg", "duration": 25, "view_count": 5798, "age_limit": 0, "webpage_url": "https://www.youtube.com/watch?v=rbX3UFDH_OE", "categories": ["Music"], "tags": ["Royalty Free Samples", "Stranger Synths", "Analogue Synths Samples", "Modular Synth Sounds", "Modular Synth loops", "Vintage Pads", "Sequences & FX Loops", "Outboard Compressors", "Loopmasters"], "playable_in_embed": true, "live_status": "not_live", "media_type": "video", "_format_sort_fields": ["quality", "res", "fps", "hdr:12", "source", "vcodec", "channels", "acodec", "lang", "proto"], "automatic_captions": {}, "subtitles": {}, "comment_count": 1, "like_count": 48, "channel": "Loopcloud", "channel_follower_count": 88300, "uploader": "Loopcloud", "uploader_id": "@loopmasters", "uploader_url": "https://www.youtube.com/@loopmasters", "upload_date": "20171026", "timestamp": 1509041388, "availability": "public", "webpage_url_basename": "watch", "webpage_url_domain": "youtube.com", "extractor": "youtube", "extractor_key": "Youtube", "playlist_count": 1, "playlist": "royalty free analog synth loops", "playlist_id": "royalty free analog synth loops", "playlist_title": "royalty free analog synth loops", "playlist_webpage_url": "ytsearch1:royalty free analog synth loops", "n_entries": 1, "playlist_index": 1,